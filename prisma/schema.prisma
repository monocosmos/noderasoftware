generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DepartmentCode {
  EXECUTIVE
  HR
  TECHNICAL
  HOUSEKEEPING
  FRONT_OFFICE
  SECURITY
  SPA
  SATIS
  FNB
  PURCHASING
  ACCOUNTING
}

enum WorkOrderStatus {
  REPORTED
  ASSIGNED
  ACCEPTED
  PURCHASE_REQUESTED
  ACCOUNTING_APPROVAL
  GM_REVIEWED
  COMPLETED
  HK_VERIFIED
  CLOSED
  CANCELLED
}

enum WorkOrderType {
  JOB
  FAULT
  PLANNED_MAINTENANCE
  PLANNED_HOUSEKEEPING
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AttachmentType {
  FILE
  PHOTO
  PDF
  EXCEL
  SIGNATURE
}

enum CalendarView {
  DAILY
  WEEKLY
  MONTHLY
  TIMELINE
}

enum PushPlatform {
  ANDROID
  IOS
  WINDOWS
  WEB
}

model Hotel {
  id          String       @id @default(cuid())
  name        String
  code        String       @unique
  timezone    String       @default("Europe/Istanbul")
  departments Department[]
  rooms       Room[]
  assets      Asset[]
  users       User[]
  reminders   Reminder[]
  managementRequests ManagementRequest[]
  operationDocuments OperationDocument[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Department {
  id             String          @id @default(cuid())
  hotelId        String
  code           String
  name           String
  hotel          Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  users          User[]
  workOrders     WorkOrder[]
  calendarEvents CalendarEvent[]
  reminders      Reminder[]
  rooms          Room[]
  assets         Asset[]
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([hotelId, code])
  @@index([hotelId, code])
}

model Role {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  departmentCode  DepartmentCode?
  users           User[]
  permissions     RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  description String
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model User {
  id                String             @id @default(cuid())
  hotelId           String
  departmentId      String
  roleId            String
  username          String             @unique
  email             String             @unique
  passwordHash      String
  fullName          String
  locale            String             @default("tr")
  moduleAccessJson  String             @default("{}")
  twoFactorEnabled  Boolean            @default(false)
  isActive          Boolean            @default(true)
  lastLoginAt       DateTime?
  deletedAt         DateTime?
  hotel             Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  department        Department         @relation(fields: [departmentId], references: [id])
  role              Role               @relation(fields: [roleId], references: [id])
  staffProfile      StaffProfile?
  sessions          AuthSession[]
  loginHistory      LoginHistory[]
  createdWorkOrders WorkOrder[]        @relation("CreatedWorkOrders")
  assignedWorkOrders WorkOrder[]       @relation("AssignedWorkOrders")
  comments          Comment[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  pushDevices       PushDevice[]
  createdReminders  Reminder[]          @relation("CreatedReminders")
  assignedReminders Reminder[]          @relation("AssignedReminders")
  createdManagementRequests ManagementRequest[] @relation("CreatedManagementRequests")
  receivedManagementRequests ManagementRequest[] @relation("ReceivedManagementRequests")
  relatedManagementRequests ManagementRequest[] @relation("RelatedManagementRequests")
  readManagementRequests ManagementRequest[] @relation("ReadManagementRequests")
  createdOperationDocuments OperationDocument[] @relation("CreatedOperationDocuments")
  operationDocumentReads OperationDocumentRead[] @relation("OperationDocumentReads")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([hotelId, departmentId])
  @@index([roleId])
}

model StaffProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  employeeNo      String    @unique
  title           String
  hireDate        DateTime
  payrollType     String?
  certificateDue  DateTime?
  digitalSignatureUrl String?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveRequests   LeaveRequest[]
  trainings       TrainingAssignment[]
}

model LeaveRequest {
  id             String          @id @default(cuid())
  staffProfileId String
  startDate      DateTime
  endDate        DateTime
  reason         String
  status         ApprovalStatus  @default(PENDING)
  staffProfile   StaffProfile    @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  approvals      Approval[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model TrainingAssignment {
  id             String       @id @default(cuid())
  staffProfileId String
  title          String
  dueDate        DateTime
  completedAt    DateTime?
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
}

model WorkOrder {
  id             String             @id @default(cuid())
  code           String             @unique
  type           WorkOrderType      @default(JOB)
  departmentId   String
  createdById    String
  assignedToId   String?
  title          String
  description    String?
  room           String?
  location       String
  tags           String?
  guestImpact    Boolean            @default(false)
  shiftCode      String?
  checklistJson  String             @default("[]")
  priority       Priority           @default(MEDIUM)
  status         WorkOrderStatus    @default(REPORTED)
  slaDueAt       DateTime?
  completedAt    DateTime?
  deletedAt      DateTime?
  department     Department         @relation(fields: [departmentId], references: [id])
  createdBy      User               @relation("CreatedWorkOrders", fields: [createdById], references: [id])
  assignedTo     User?              @relation("AssignedWorkOrders", fields: [assignedToId], references: [id])
  timeline       WorkOrderTimeline[]
  comments       Comment[]
  attachments    Attachment[]
  purchaseRequests PurchaseRequest[]
  approvals      Approval[]
  auditLogs      AuditLog[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([departmentId, status])
  @@index([assignedToId])
  @@index([deletedAt])
}

model WorkOrderTimeline {
  id          String          @id @default(cuid())
  workOrderId String
  actorId     String?
  status      WorkOrderStatus
  message     String
  metadata    Json?
  workOrder   WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())

  @@index([workOrderId, createdAt])
}

model Comment {
  id          String    @id @default(cuid())
  workOrderId String
  authorId    String
  body        String
  deletedAt   DateTime?
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Attachment {
  id          String         @id @default(cuid())
  workOrderId String?
  uploaderId  String?
  type        AttachmentType @default(FILE)
  fileName    String
  mimeType    String
  size        Int
  bucket      String
  objectKey   String
  publicUrl   String?
  checksum    String?
  phase       String         @default("GENERAL")
  workOrder   WorkOrder?     @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
}

model CalendarEvent {
  id           String       @id @default(cuid())
  departmentId String
  title        String
  description  String?
  view         CalendarView @default(WEEKLY)
  startsAt     DateTime
  endsAt       DateTime
  loadScore    Int          @default(0)
  createdById  String
  deletedAt    DateTime?
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([departmentId, startsAt])
}

model Room {
  id           String       @id @default(cuid())
  hotelId      String
  departmentId String?
  number       String
  floor        Int
  status       String
  vipBlocked   Boolean      @default(false)
  hotel        Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  department   Department?  @relation(fields: [departmentId], references: [id])
  histories    RoomStatusHistory[]

  @@unique([hotelId, number])
}

model RoomStatusHistory {
  id        String   @id @default(cuid())
  roomId    String
  status    String
  actorId   String
  note      String?
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Asset {
  id           String      @id @default(cuid())
  hotelId      String
  departmentId String
  code         String      @unique
  name         String
  location     String
  warrantyUntil DateTime?
  hotel        Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Approval {
  id                String           @id @default(cuid())
  approverId        String
  status            ApprovalStatus   @default(PENDING)
  note              String?
  workOrderId       String?
  leaveRequestId    String?
  purchaseRequestId String?
  workOrder         WorkOrder?       @relation(fields: [workOrderId], references: [id])
  leaveRequest      LeaveRequest?    @relation(fields: [leaveRequestId], references: [id])
  purchaseRequest   PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model PurchaseRequest {
  id          String         @id @default(cuid())
  workOrderId String?
  requesterId String
  costCenter  String
  title       String
  amount      Decimal        @db.Decimal(12, 2)
  currency    String         @default("TRY")
  status      ApprovalStatus @default(PENDING)
  workOrder   WorkOrder?     @relation(fields: [workOrderId], references: [id])
  approvals   Approval[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model PushDevice {
  id         String       @id @default(cuid())
  userId     String
  sessionId  String?
  platform   PushPlatform @default(ANDROID)
  fcmToken   String       @unique
  deviceId   String?
  appVersion String?
  userAgent  String?
  lastSeenAt DateTime     @default(now())
  disabledAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([platform])
  @@index([sessionId])
  @@index([userId, disabledAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  channel   String    @default("IN_APP")
  readAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

model Reminder {
  id                 String      @id @default(cuid())
  hotelId            String
  departmentId       String
  createdById        String
  assignedToId       String
  title              String
  body               String?
  photosJson         String      @default("[]")
  remindAt           DateTime
  oneHourNotifiedAt  DateTime?
  dueNotifiedAt      DateTime?
  completedAt        DateTime?
  deletedAt          DateTime?
  hotel              Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  department         Department  @relation(fields: [departmentId], references: [id])
  createdBy          User        @relation("CreatedReminders", fields: [createdById], references: [id])
  assignedTo         User        @relation("AssignedReminders", fields: [assignedToId], references: [id])
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([hotelId, departmentId, remindAt])
  @@index([assignedToId, remindAt])
}

model ManagementRequest {
  id            String      @id @default(cuid())
  hotelId       String
  createdById   String
  recipientId   String
  relatedUserId String?
  readById      String?
  title         String
  body          String?
  status        String      @default("OPEN")
  readAt        DateTime?
  deletedAt     DateTime?
  hotel         Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  createdBy     User        @relation("CreatedManagementRequests", fields: [createdById], references: [id])
  recipient     User        @relation("ReceivedManagementRequests", fields: [recipientId], references: [id])
  relatedUser   User?       @relation("RelatedManagementRequests", fields: [relatedUserId], references: [id])
  readBy        User?       @relation("ReadManagementRequests", fields: [readById], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([hotelId, createdById, recipientId, relatedUserId])
  @@index([recipientId, status])
  @@index([relatedUserId, status])
  @@index([readAt])
}

model OperationDocument {
  id                  String                  @id @default(cuid())
  hotelId             String
  createdById         String
  operationDefinition String
  operationDate       DateTime
  description         String?
  fileName            String
  mimeType            String
  fileSize            Int
  fileDataUrl         String                  @db.Text
  deletedAt           DateTime?
  hotel               Hotel                   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  createdBy           User                    @relation("CreatedOperationDocuments", fields: [createdById], references: [id])
  reads               OperationDocumentRead[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([hotelId, operationDate])
  @@index([createdById])
}

model OperationDocumentRead {
  id         String            @id @default(cuid())
  documentId String
  userId     String
  readAt     DateTime          @default(now())
  document   OperationDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User              @relation("OperationDocumentReads", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
  @@index([userId, readAt])
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  ipAddress    String
  userAgent    String
  expiresAt    DateTime
  revokedAt    DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model LoginHistory {
  id          String   @id @default(cuid())
  userId      String
  ipAddress   String
  userAgent   String
  success     Boolean
  reason      String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

model AuditLog {
  id          String     @id @default(cuid())
  actorId     String
  entityType  String
  entityId    String
  action      String
  before      Json?
  after       Json?
  ipAddress   String?
  userAgent   String?
  workOrderId String?
  actor       User       @relation(fields: [actorId], references: [id])
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])
  createdAt   DateTime   @default(now())

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
}
