<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <defaultDocument enabled="true">
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
    </staticContent>
    <httpProtocol>
      <customHeaders>
        <remove name="Cache-Control" />
        <remove name="Pragma" />
        <remove name="Expires" />
        <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
        <add name="Pragma" value="no-cache" />
        <add name="Expires" value="0" />
      </customHeaders>
    </httpProtocol>
    <rewrite>
      <rules>
        <rule name="Nodera Sistem Canonical HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_URI}" pattern="^/\.well-known/acme-challenge/" negate="true" />
            <add input="{HTTP_HOST}" pattern="^(127\.0\.0\.1|localhost)(:\d+)?$" negate="true" />
            <add input="{HTTPS}" pattern="on" negate="true" />
          </conditions>
          <action type="Redirect" url="https://noderasoftware.com/{R:1}" redirectType="Permanent" />
        </rule>
        <rule name="Nodera Sistem Canonical Host" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_URI}" pattern="^/\.well-known/acme-challenge/" negate="true" />
            <add input="{HTTP_HOST}" pattern="^noderasoftware\.com$" negate="true" />
            <add input="{HTTP_HOST}" pattern="^(127\.0\.0\.1|localhost)(:\d+)?$" negate="true" />
            <add input="{HTTPS}" pattern="on" />
          </conditions>
          <action type="Redirect" url="https://noderasoftware.com/{R:1}" redirectType="Permanent" />
        </rule>
        <rule name="Nodera Sistem Legacy Path Redirect" stopProcessing="true">
          <match url="^(login|dashboard|jobs(?:/.*)?|maintenance|housekeeping|calendar(?:/.*)?|reminders|reports|users|settings)/?$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_URI}" pattern="^/\.well-known/acme-challenge/" negate="true" />
          </conditions>
          <action type="Redirect" url="/hotel/{R:0}" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Nodera Sistem API Proxy" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:4000/{R:1}" />
        </rule>
        <rule name="Nodera Sistem Socket Proxy" stopProcessing="true">
          <match url="^socket.io/(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:4000/socket.io/{R:1}" />
        </rule>
      </rules>
    </rewrite>
    <httpErrors errorMode="DetailedLocalOnly" existingResponse="PassThrough" />
  </system.webServer>
</configuration>
